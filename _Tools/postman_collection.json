{
  "info": {
    "name": "Guest Desk API",
    "description": "Full test collection for the openDelivery backend.\n\n**Run order (first time):**\n1. `1a. Login — Platform Admin`\n2. `2a. Create Owner` — saves owner_id, owner_schema, owner_email, owner_temp_password\n3. `1b. Login — Owner` — uses owner_schema and owner_temp_password saved above\n4. `3a. Create Property` — saves property_id\n5. `4a. Create Device` — saves device_id, activation_code\n6. `4d. Activate Device` — uses activation_code (no auth, kiosk flow)\n7. `5a. Create Product` — saves product_id\n8. `6a. Create Order` — saves order_id (no auth, kiosk flow)\n\n> Payments (section 7) are pending Phase 3B and will return 404.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",             "value": "http://localhost:8080/api" },
    { "key": "admin_token",         "value": "" },
    { "key": "admin_refresh",       "value": "" },
    { "key": "owner_token",         "value": "" },
    { "key": "owner_refresh",       "value": "" },
    { "key": "owner_id",            "value": "" },
    { "key": "owner_schema",        "value": "" },
    { "key": "owner_email",         "value": "" },
    { "key": "owner_temp_password", "value": "" },
    { "key": "property_id",         "value": "" },
    { "key": "device_id",           "value": "" },
    { "key": "activation_code",     "value": "" },
    { "key": "product_id",          "value": "" },
    { "key": "order_id",            "value": "" },
    { "key": "payment_id",          "value": "" }
  ],
  "item": [

    {
      "name": "0. Health",
      "item": [
        {
          "name": "0a. Health Check",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": ["pm.test(\"Status 200\", () => pm.response.to.have.status(200));"]
            }
          }],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },

    {
      "name": "1. Auth",
      "item": [
        {
          "name": "1a. Login — Platform Admin",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set(\"admin_token\", json.accessToken);",
                "pm.collectionVariables.set(\"admin_refresh\", json.refreshToken);",
                "console.log(\"Admin token saved. Role: \" + json.role);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@guestdesk.io\",\n  \"password\": \"Admin@GuestDesk1\",\n  \"role\": \"PLATFORM_ADMIN\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "1b. Login — Owner",
          "description": "Run AFTER 2a (Create Owner). Uses owner_email, owner_temp_password and owner_schema saved by that request.",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set(\"owner_token\", json.accessToken);",
                "pm.collectionVariables.set(\"owner_refresh\", json.refreshToken);",
                "console.log(\"Owner token saved. Schema: \" + pm.collectionVariables.get(\"owner_schema\"));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{owner_email}}\",\n  \"password\": \"{{owner_temp_password}}\",\n  \"role\": \"OWNER\",\n  \"schemaName\": \"{{owner_schema}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "1c. Refresh Token — Admin",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set(\"admin_token\", json.accessToken);",
                "pm.collectionVariables.set(\"admin_refresh\", json.refreshToken);",
                "console.log(\"Admin tokens rotated.\");"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{admin_refresh}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/refresh"
          }
        },
        {
          "name": "1d. Login — Wrong Password (expect 401)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": ["pm.test(\"Status 401\", () => pm.response.to.have.status(401));"]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@guestdesk.io\",\n  \"password\": \"wrongpassword\",\n  \"role\": \"PLATFORM_ADMIN\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },

    {
      "name": "2. Owners (Platform Admin)",
      "item": [
        {
          "name": "2a. Create Owner",
          "description": "Creates an INDIVIDUAL owner. The backend auto-generates a temporaryPassword returned in the response. Save it — it is shown only once.",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test(\"Status 201\", () => pm.response.to.have.status(201));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set(\"owner_id\", json.id);",
                "pm.collectionVariables.set(\"owner_schema\", json.schemaName);",
                "pm.collectionVariables.set(\"owner_email\", json.contactEmail);",
                "pm.collectionVariables.set(\"owner_temp_password\", json.temporaryPassword);",
                "console.log(\"Owner created. ID: \" + json.id + \" Schema: \" + json.schemaName + \" TempPass: \" + json.temporaryPassword);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ownerType\": \"INDIVIDUAL\",\n  \"firstName\": \"Nikos\",\n  \"lastName\": \"Papadopoulos\",\n  \"vatId\": \"123456789\",\n  \"contactEmail\": \"owner@testhotel.gr\",\n  \"contactPhone\": \"+30 210 0000000\",\n  \"subscriptionPriceCents\": 120000\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/owners"
          }
        },
        {
          "name": "2b. List Owners",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": ["pm.test(\"Status 200\", () => pm.response.to.have.status(200));"]
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": "{{baseUrl}}/owners"
          }
        },
        {
          "name": "2c. Get Owner by ID",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": ["pm.test(\"Status 200\", () => pm.response.to.have.status(200));"]
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": "{{baseUrl}}/owners/{{owner_id}}"
          }
        },
        {
          "name": "2d. Update Owner",
          "description": "ownerType, contactEmail and vatId are read-only and excluded from the update body.",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": ["pm.test(\"Status 200\", () => pm.response.to.have.status(200));"]
            }
          }],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Nikolaos\",\n  \"lastName\": \"Papadopoulos\",\n  \"contactPhone\": \"+30 210 1234567\",\n  \"subscriptionPriceCents\": 150000\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/owners/{{owner_id}}"
          }
        },
        {
          "name": "2e. Get Owner — Not Found (expect 404)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": ["pm.test(\"Status 404\", () => pm.response.to.have.status(404));"]
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": "{{baseUrl}}/owners/00000000-0000-0000-0000-000000000000"
          }
        },
        {
          "name": "2f. Delete Owner",
          "description": "Hard delete — removes the owner and drops their tenant schema. Irreversible.",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": ["pm.test(\"Status 204\", () => pm.response.to.have.status(204));"]
            }
          }],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": "{{baseUrl}}/owners/{{owner_id}}"
          }
        }
      ]
    },

