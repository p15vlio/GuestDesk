    {
      "name": "4. Devices (Owner)",
      "item": [
        {
          "name": "4a. Create Device",
          "description": "Creates a device without an Android ID. The backend generates an activation code and QR code PNG (base64). The kiosk scans the QR to activate itself via 4d.",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test(\"Status 201\", () => pm.response.to.have.status(201));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set(\"device_id\", json.id);",
                "pm.collectionVariables.set(\"activation_code\", json.activationCode);",
                "console.log(\"Device created. ID: \" + json.id + \" Activation code: \" + json.activationCode);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{owner_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Kiosk Tablet 1\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/properties/{{property_id}}/devices"
          }
        },
        {
          "name": "4b. List Devices for Property",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": ["pm.test(\"Status 200\", () => pm.response.to.have.status(200));"]
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{owner_token}}" }],
            "url": "{{baseUrl}}/properties/{{property_id}}/devices"
          }
        },
        {
          "name": "4c. Get Device by ID",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": ["pm.test(\"Status 200\", () => pm.response.to.have.status(200));"]
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{owner_token}}" }],
            "url": "{{baseUrl}}/devices/{{device_id}}"
          }
        },
        {
          "name": "4d. Activate Device (QR flow — no auth)",
          "description": "No JWT required. The kiosk sends the scanned activation code and its hardware Android ID. Backend activates the device and clears the activation code.",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": ["pm.test(\"Status 200\", () => pm.response.to.have.status(200));"]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"activationCode\": \"{{activation_code}}\",\n  \"androidDeviceId\": \"emulator-5554\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/devices/{{device_id}}/activate?schemaName={{owner_schema}}",
              "host": ["{{baseUrl}}"],
              "path": ["devices", "{{device_id}}", "activate"],
              "query": [{ "key": "schemaName", "value": "{{owner_schema}}" }]
            }
          }
        },
        {
          "name": "4e. Ping Device (no auth — kiosk heartbeat)",
          "description": "Simulates the kiosk sending a heartbeat. No JWT required. Passes schemaName as query param.",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": ["pm.test(\"Status 204\", () => pm.response.to.have.status(204));"]
            }
          }],
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/devices/{{device_id}}/ping?schemaName={{owner_schema}}",
              "host": ["{{baseUrl}}"],
              "path": ["devices", "{{device_id}}", "ping"],
              "query": [{ "key": "schemaName", "value": "{{owner_schema}}" }]
            }
          }
        },
        {
          "name": "4f. Delete Device",
          "description": "Hard delete — irreversible.",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": ["pm.test(\"Status 204\", () => pm.response.to.have.status(204));"]
            }
          }],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{owner_token}}" }],
            "url": "{{baseUrl}}/devices/{{device_id}}"
          }
        }
      ]
    },

