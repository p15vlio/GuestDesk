{
  "info": {
    "name": "openDelivery API",
    "description": "Full test collection for the openDelivery backend.\n\n**Run order (first time):**\n1. `1a. Login — Platform Admin`\n2. `2a. Create Owner` — saves owner_id and owner_schema\n3. `1b. Login — Owner` — uses owner_schema saved above\n4. `3a. Create Property` — saves property_id\n5. `4a. Create Device` — saves device_id\n6. `5a. Create Product` — saves product_id\n7. `6a. Create Order` — saves order_id (no auth, kiosk flow)\n8. `7a. Initiate Payment` — saves payment_id (no auth, kiosk flow)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",             "value": "http://localhost:8080/api" },
    { "key": "admin_token",         "value": "" },
    { "key": "admin_refresh",       "value": "" },
    { "key": "owner_token",         "value": "" },
    { "key": "owner_refresh",       "value": "" },
    { "key": "owner_id",            "value": "" },
    { "key": "owner_schema",        "value": "" },
    { "key": "property_id",         "value": "" },
    { "key": "device_id",           "value": "" },
    { "key": "product_id",          "value": "" },
    { "key": "order_id",            "value": "" },
    { "key": "payment_id",          "value": "" }
  ],
  "item": [

    {
      "name": "1. Auth",
      "item": [
        {
          "name": "1a. Login — Platform Admin",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set(\"admin_token\", json.accessToken);",
                "pm.collectionVariables.set(\"admin_refresh\", json.refreshToken);",
                "console.log(\"Admin token saved. Role: \" + json.role);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@kustax.net\",\n  \"password\": \"nwDC31!skgpbyr\",\n  \"role\": \"PLATFORM_ADMIN\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "1b. Login — Owner",
          "description": "Run AFTER 2a (Create Owner). Uses owner_schema saved by that request.",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set(\"owner_token\", json.accessToken);",
                "pm.collectionVariables.set(\"owner_refresh\", json.refreshToken);",
                "console.log(\"Owner token saved. Schema: \" + pm.collectionVariables.get(\"owner_schema\"));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@testhotel.com\",\n  \"password\": \"Owner1234!\",\n  \"role\": \"OWNER\",\n  \"schemaName\": \"{{owner_schema}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "1c. Refresh Token — Admin",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set(\"admin_token\", json.accessToken);",
                "pm.collectionVariables.set(\"admin_refresh\", json.refreshToken);",
                "console.log(\"Admin tokens rotated.\");"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{admin_refresh}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/refresh"
          }
        },
        {
          "name": "1d. Login — Wrong Password (expect 401)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": ["pm.test(\"Status 401\", () => pm.response.to.have.status(401));"]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@kustax.net\",\n  \"password\": \"wrongpassword\",\n  \"role\": \"PLATFORM_ADMIN\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },

