    {
      "name": "6. Orders (Kiosk — no auth)",
      "item": [
        {
          "name": "6a. Create Order",
          "description": "No JWT required. Kiosk flow. Passes schemaName, deviceId, propertyId as query params.",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test(\"Status 201\", () => pm.response.to.have.status(201));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set(\"order_id\", json.id);",
                "console.log(\"Order created. ID: \" + json.id + \" Status: \" + json.status);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"guestEmail\": \"guest@example.com\",\n  \"type\": \"IN_ROOM_STORE\",\n  \"partnerStoreId\": null,\n  \"items\": [\n    {\n      \"productId\": \"{{product_id}}\",\n      \"quantity\": 2\n    }\n  ],\n  \"notes\": \"Please leave at door\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/orders?schemaName={{owner_schema}}&deviceId={{device_id}}&propertyId={{property_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["orders"],
              "query": [
                { "key": "schemaName",  "value": "{{owner_schema}}" },
                { "key": "deviceId",    "value": "{{device_id}}" },
                { "key": "propertyId",  "value": "{{property_id}}" }
              ]
            }
          }
        },
        {
          "name": "6b. List Orders for Property (Owner)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": ["pm.test(\"Status 200\", () => pm.response.to.have.status(200));"]
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{owner_token}}" }],
            "url": {
              "raw": "{{baseUrl}}/orders?propertyId={{property_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["orders"],
              "query": [{ "key": "propertyId", "value": "{{property_id}}" }]
            }
          }
        },
        {
          "name": "6c. Get Order by ID (Owner)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": ["pm.test(\"Status 200\", () => pm.response.to.have.status(200));"]
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{owner_token}}" }],
            "url": "{{baseUrl}}/orders/{{order_id}}"
          }
        },
        {
          "name": "6d. Update Order Status — PREPARING (Owner)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": ["pm.test(\"Status 200\", () => pm.response.to.have.status(200));"]
            }
          }],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{owner_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"PREPARING\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/orders/{{order_id}}/status"
          }
        },
        {
          "name": "6e. Update Order Status — DELIVERED (Owner)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": ["pm.test(\"Status 200\", () => pm.response.to.have.status(200));"]
            }
          }],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{owner_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"DELIVERED\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/orders/{{order_id}}/status"
          }
        },
        {
          "name": "6f. Invalid Status Transition (expect 409)",
          "description": "Order is already DELIVERED — any further transition should return 409.",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": ["pm.test(\"Status 409\", () => pm.response.to.have.status(409));"]
            }
          }],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{owner_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CANCELLED\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/orders/{{order_id}}/status"
          }
        }
      ]
    },

    {
      "name": "7. Payments (Kiosk — no auth)",
      "item": [
        {
          "name": "7a. Initiate Payment",
          "description": "No JWT required. Kiosk flow. Passes schemaName as query param.",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test(\"Status 201\", () => pm.response.to.have.status(201));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set(\"payment_id\", json.id);",
                "console.log(\"Payment completed. ID: \" + json.id + \" Status: \" + json.status);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{order_id}}\",\n  \"method\": \"REVOLUT\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/payments?schemaName={{owner_schema}}",
              "host": ["{{baseUrl}}"],
              "path": ["payments"],
              "query": [{ "key": "schemaName", "value": "{{owner_schema}}" }]
            }
          }
        },
        {
          "name": "7b. Pay Already-Paid Order (expect 409)",
          "description": "Second payment on same order should return 409 Conflict.",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": ["pm.test(\"Status 409\", () => pm.response.to.have.status(409));"]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{order_id}}\",\n  \"method\": \"REVOLUT\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/payments?schemaName={{owner_schema}}",
              "host": ["{{baseUrl}}"],
              "path": ["payments"],
              "query": [{ "key": "schemaName", "value": "{{owner_schema}}" }]
            }
          }
        },
        {
          "name": "7c. Get Payment by Order ID (Owner)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": ["pm.test(\"Status 200\", () => pm.response.to.have.status(200));"]
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{owner_token}}" }],
            "url": "{{baseUrl}}/orders/{{order_id}}/payment"
          }
        }
      ]
    }

  ]
}
